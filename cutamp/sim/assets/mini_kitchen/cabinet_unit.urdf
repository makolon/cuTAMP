<?xml version="1.0"?>
<robot name="cabinet_unit">
  <link name="body">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.14 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.42 0.02 0.34"/>
      </geometry>
      <material name="frame_color">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="left_wall_joint" type="fixed">
    <parent link="body"/>
    <child link="left_wall"/>
    <origin xyz="-0.20 0 0" rpy="0 0 0"/>
  </joint>
  <link name="left_wall">
    <visual>
      <geometry>
        <box size="0.02 0.26 0.34"/>
      </geometry>
      <material name="frame_color_left">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="right_wall_joint" type="fixed">
    <parent link="body"/>
    <child link="right_wall"/>
    <origin xyz="0.20 0 0" rpy="0 0 0"/>
  </joint>
  <link name="right_wall">
    <visual>
      <geometry>
        <box size="0.02 0.26 0.34"/>
      </geometry>
      <material name="frame_color_right">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="bottom_joint" type="fixed">
    <parent link="body"/>
    <child link="bottom_panel"/>
    <origin xyz="0 0 -0.16" rpy="0 0 0"/>
  </joint>
  <link name="bottom_panel">
    <visual>
      <geometry>
        <box size="0.42 0.26 0.02"/>
      </geometry>
      <material name="frame_color_bottom">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="top_joint" type="fixed">
    <parent link="body"/>
    <child link="top_panel"/>
    <origin xyz="0 0 0.16" rpy="0 0 0"/>
  </joint>
  <link name="top_panel">
    <visual>
      <geometry>
        <box size="0.42 0.26 0.02"/>
      </geometry>
      <material name="frame_color_top">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="door_hinge" type="revolute">
    <parent link="body"/>
    <child link="door"/>
    <origin xyz="-0.19 0.14 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.0" upper="1.57" effort="1.0" velocity="1.0"/>
  </joint>
  <link name="door">
    <visual>
      <origin xyz="0.19 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.02 0.30"/>
      </geometry>
      <material name="door_color">
        <color rgba="0.89 0.87 0.83 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="door_handle_joint" type="fixed">
    <parent link="door"/>
    <child link="door_handle"/>
    <origin xyz="0.29 0.02 0" rpy="0 0 0"/>
  </joint>
  <link name="door_handle">
    <visual>
      <geometry>
        <box size="0.06 0.04 0.08"/>
      </geometry>
      <material name="handle_color">
        <color rgba="0.54 0.56 0.59 1.0"/>
      </material>
    </visual>
  </link>
</robot>
