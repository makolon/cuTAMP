<?xml version="1.0"?>
<robot name="counter">
  <link name="top">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.62 0.44 0.04"/>
      </geometry>
      <material name="counter_top">
        <color rgba="0.80 0.84 0.76 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="base_body_joint" type="fixed">
    <parent link="top"/>
    <child link="base_body"/>
    <origin xyz="0 0 -0.14" rpy="0 0 0"/>
  </joint>
  <link name="base_body">
    <visual>
      <geometry>
        <box size="0.56 0.40 0.24"/>
      </geometry>
      <material name="base_body_color">
        <color rgba="0.88 0.85 0.79 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="kickplate_joint" type="fixed">
    <parent link="top"/>
    <child link="kickplate"/>
    <origin xyz="0 0.18 -0.24" rpy="0 0 0"/>
  </joint>
  <link name="kickplate">
    <visual>
      <geometry>
        <box size="0.56 0.04 0.04"/>
      </geometry>
      <material name="kickplate_color">
        <color rgba="0.68 0.63 0.58 1.0"/>
      </material>
    </visual>
  </link>
</robot>
