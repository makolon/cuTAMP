<?xml version="1.0"?>
<robot name="bowl">
  <link name="body">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="bowl_body">
        <color rgba="0.67 0.78 1.00 1.0"/>
      </material>
    </visual>
  </link>
</robot>
