<?xml version="1.0"?>
<robot name="drawer_unit">
  <link name="body">
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0 -0.13 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.42 0.02 0.18"/>
      </geometry>
      <material name="frame_color">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="left_wall_joint" type="fixed">
    <parent link="body"/>
    <child link="left_wall"/>
    <origin xyz="-0.20 0 0" rpy="0 0 0"/>
  </joint>
  <link name="left_wall">
    <visual>
      <geometry>
        <box size="0.02 0.24 0.18"/>
      </geometry>
      <material name="frame_color_left">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="right_wall_joint" type="fixed">
    <parent link="body"/>
    <child link="right_wall"/>
    <origin xyz="0.20 0 0" rpy="0 0 0"/>
  </joint>
  <link name="right_wall">
    <visual>
      <geometry>
        <box size="0.02 0.24 0.18"/>
      </geometry>
      <material name="frame_color_right">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="bottom_joint" type="fixed">
    <parent link="body"/>
    <child link="bottom_panel"/>
    <origin xyz="0 0 -0.08" rpy="0 0 0"/>
  </joint>
  <link name="bottom_panel">
    <visual>
      <geometry>
        <box size="0.42 0.24 0.02"/>
      </geometry>
      <material name="frame_color_bottom">
        <color rgba="0.81 0.78 0.74 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="drawer_slide" type="prismatic">
    <parent link="body"/>
    <child link="drawer_box"/>
    <origin xyz="0 0.13 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.0" upper="0.20" effort="1.0" velocity="1.0"/>
  </joint>
  <link name="drawer_box">
    <visual>
      <origin xyz="0 -0.09 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.36 0.18 0.12"/>
      </geometry>
      <material name="drawer_box_color">
        <color rgba="0.93 0.92 0.89 1.0"/>
      </material>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.38 0.02 0.14"/>
      </geometry>
      <material name="drawer_front_color">
        <color rgba="0.89 0.87 0.83 1.0"/>
      </material>
    </visual>
  </link>
  <joint name="drawer_handle_joint" type="fixed">
    <parent link="drawer_box"/>
    <child link="drawer_handle"/>
    <origin xyz="0 0.02 0" rpy="0 0 0"/>
  </joint>
  <link name="drawer_handle">
    <visual>
      <geometry>
        <box size="0.08 0.04 0.05"/>
      </geometry>
      <material name="handle_color">
        <color rgba="0.54 0.56 0.59 1.0"/>
      </material>
    </visual>
  </link>
</robot>
