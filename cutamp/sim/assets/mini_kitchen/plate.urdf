<?xml version="1.0"?>
<robot name="plate">
  <link name="body">
    <inertial>
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
    <visual>
      <geometry>
        <cylinder radius="0.07" length="0.025"/>
      </geometry>
      <material name="plate_body">
        <color rgba="0.96 0.96 0.95 1.0"/>
      </material>
    </visual>
  </link>
</robot>
