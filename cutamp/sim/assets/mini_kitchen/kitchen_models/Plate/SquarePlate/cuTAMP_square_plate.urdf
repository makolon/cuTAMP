<?xml version="1.0" ?>
<robot name="cutamp_square_plate">
  <link name="base"/>
  <link name="body">
    <visual>
      <origin xyz="-0.00005 0.00005 -1.5092"/>
      <geometry>
        <mesh filename="Square.obj"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="-0.00005 0.00005 -1.5092"/>
      <geometry>
        <mesh filename="Square.obj"/>
      </geometry>
    </collision>
  </link>
  <joint name="body_fixed" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <child link="body"/>
    <parent link="base"/>
  </joint>
</robot>
